<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.telewhat.auth.AuthController">
   <children>
      <Text layoutX="136.0" layoutY="88.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Username" />
      <TextField layoutX="210.0" layoutY="71.0" fx:id="idUsername" />
      <Text layoutX="147.0" layoutY="173.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Mot de passe" />
      <TextField layoutX="221.0" layoutY="156.0"  fx:id="idPassword"/>

      <Button layoutX="233.0" layoutY="241.0" mnemonicParsing="false" fx:id="btn_login" text="Connexion" onAction="#loginAction"/>
   </children>
</AnchorPane>
