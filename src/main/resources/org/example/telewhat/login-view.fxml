      <TextField fx:id="idUsername" layoutX="252.0" layoutY="71.0" />
      <Text layoutX="155.0" layoutY="173.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Mot de passe" />
      <TextField fx:id="idPassword" layoutX="252.0" layoutY="156.0" />
      <Button fx:id="btn_login" layoutX="264.0" layoutY="240.0" mnemonicParsing="false" onAction="#loginAction" text="Connexion" />
