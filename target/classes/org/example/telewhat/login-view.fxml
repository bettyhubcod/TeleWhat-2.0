       <TextField fx:id="idPasswordVisible" layoutX="102.0" layoutY="241.0" prefHeight="36.0" prefWidth="267.0" promptText="Mot de Passe" visible="false" style="-fx-background-radius: 20px; -fx-background-color: #132019; -fx-border-color: white; -fx-border-radius: 20px; -fx-border-width: 0.2px; -fx-text-fill: white;"/>
      <ImageView fitHeight="17.0" fitWidth="21.0" layoutX="331.0" layoutY="199.0" pickOnBounds="true" preserveRatio="true">
