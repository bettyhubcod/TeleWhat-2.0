<AnchorPane prefHeight="463.0" prefWidth="899.0" style="-fx-background-color: #0b140f;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.telewhat.auth.AuthController">
