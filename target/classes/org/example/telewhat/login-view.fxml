      <StackPane fx:id="imagePane" layoutX="457.0" layoutY="17.0" prefHeight="419.0" prefWidth="402.0" style="-fx-background-color: #367d53; -fx-border-radius: 20px; -fx-background-radius: 20px;" />
      <Text fill="WHITE" layoutX="162.0" layoutY="125.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Bon retour !">
